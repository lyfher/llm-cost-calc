---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Calculate and compare LLM API costs across OpenAI, Anthropic, Google, Mistral and more. Free tool for developers." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">
    <nav class="border-b border-gray-800 bg-gray-950/80 backdrop-blur sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-white text-lg tracking-tight">
          LLM<span class="text-violet-400">Cost</span>
        </a>
        <div class="flex gap-6 text-sm text-gray-400">
          <a href="/" class="hover:text-white transition-colors">Calculator</a>
          <a href="/compare" class="hover:text-white transition-colors">Compare All</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="border-t border-gray-800 mt-20 py-8 text-center text-sm text-gray-600">
      Prices are approximate. Always verify at each provider's pricing page.
      Last updated: April 2026.
    </footer>
  </body>
</html>
<style is:global>
  @import "../styles/global.css";
</style>
